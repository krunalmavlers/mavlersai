# ---------------------------------------------------------------------------
# Mavlers.ai — environment variables
# Copy this file to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# --- Supabase (required) ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose this to the browser. Used for admin mutations,
# storing form submissions, and reading drafts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
# Absolute base URL of the deployed site (used for canonical URLs, sitemap, OG).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- reCAPTCHA v3 (recommended) ---
# From https://www.google.com/recaptcha/admin  (choose reCAPTCHA v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key
# Minimum score (0.0 - 1.0) to accept a submission. 0.5 is a sensible default.
RECAPTCHA_MIN_SCORE=0.5

# --- Email (optional — off by default) ---
# Leave EMAIL_PROVIDER unset/"none" to store submissions in the DB only.
# Set to "resend" and provide a key to enable email notifications.
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM="Mavlers.ai <notifications@yourdomain.com>"
